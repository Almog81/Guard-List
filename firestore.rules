rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // כולם יכולים לקרוא הכל
    match /{document=**} {
      allow read: if true;
    }

    // כתיבה רק למשתמש מאומת (האדמין)
    match /teams/{teamId} {
      allow write: if request.auth != null;
    }
    match /soldiers/{soldierId} {
      allow write: if request.auth != null;
    }
    match /settings/{settingId} {
      allow write: if request.auth != null;
    }
    match /schedule/{date} {
      allow write: if request.auth != null;
    }
  }
}
